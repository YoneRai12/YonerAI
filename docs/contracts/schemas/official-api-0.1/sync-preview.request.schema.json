{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yonerai.com/contracts/official-api-0.1/sync-preview.request.schema.json",
  "title": "YonerAI Official API sync preview request 0.1",
  "type": "object",
  "required": ["direction", "conversation_ref", "audit_reason"],
  "properties": {
    "direction": {"enum": ["cloud_to_local", "local_to_cloud"]},
    "conversation_ref": {"type": "string"},
    "audit_reason": {"type": "string", "minLength": 1},
    "contains_private_content": {"type": "boolean"}
  },
  "additionalProperties": false
}
