{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://status.yonerai.com/status-healthcheck.schema.json",
  "title": "YonerAI Status healthcheck input v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "range",
    "categories"
  ],
  "properties": {
    "schema_version": {
      "const": "yonerai.status.healthcheck.v1"
    },
    "generated_at": {
      "type": "string"
    },
    "result_date": {
      "$ref": "#/$defs/date"
    },
    "locale_default": {
      "type": "string",
      "enum": [
        "ja",
        "en"
      ]
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "days"
      ],
      "properties": {
        "start": {
          "$ref": "#/$defs/date"
        },
        "days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        }
      }
    },
        "contract_note": {
          "$ref": "#/$defs/localizedText"
        },
        "aws_metric_fill": {
          "type": "object",
          "additionalProperties": true
        },
        "yonerai_health_fill": {
          "type": "object",
          "additionalProperties": true
        },
        "states": {
          "type": "object",
          "additionalProperties": {
        "$ref": "#/$defs/stateDef"
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/healthcheckCategory"
      }
    },
    "incidents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/publicIncident"
      }
    }
  },
  "$defs": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$",
      "not": {
        "const": "__category__"
      }
    },
    "state": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "localizedText": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "ja": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            },
            "en": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            }
          }
        }
      ]
    },
    "stateDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "className": {
          "type": "string"
        },
        "severity": {
          "type": "number"
        }
      }
    },
    "healthcheckCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/healthcheckComponent"
          }
        },
        "children": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/healthcheckComponent"
          }
        }
      },
      "oneOf": [
        {
          "required": [
            "components"
          ]
        },
        {
          "required": [
            "children"
          ]
        }
      ]
    },
    "healthcheckComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "default_state"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "fact": {
          "$ref": "#/$defs/localizedText"
        },
        "monitoring": {
          "$ref": "#/$defs/localizedText"
        },
        "claim": {
          "$ref": "#/$defs/localizedText"
        },
        "state": {
          "$ref": "#/$defs/state"
        },
        "default_state": {
          "$ref": "#/$defs/state"
        },
        "default_message": {
          "$ref": "#/$defs/localizedText"
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/check"
          }
        }
      }
    },
    "check": {
      "oneOf": [
        {
          "$ref": "#/$defs/staticCheck"
        },
        {
          "$ref": "#/$defs/httpCheck"
        },
        {
          "$ref": "#/$defs/awsMetricCheck"
        }
      ]
    },
    "staticCheck": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "enum": [
            "static",
            "manual"
          ]
        },
        "state": {
          "$ref": "#/$defs/state"
        },
        "label": {
          "type": "string"
        },
        "message": {
          "$ref": "#/$defs/localizedText"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "httpCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "url"
      ],
      "properties": {
        "type": {
          "const": "http"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string"
        },
        "status_min": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "status_max": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "degraded_ms": {
          "type": "integer",
          "minimum": 0
        },
        "label": {
          "type": "string"
        },
        "message": {
          "$ref": "#/$defs/localizedText"
        },
        "message_on_error": {
          "$ref": "#/$defs/localizedText"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "source": {
          "type": "string"
        }
      }
    },
    "awsMetricCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "namespace",
        "metric_name"
      ],
      "properties": {
        "type": {
          "const": "aws_metric"
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "metric_name": {
          "type": "string",
          "minLength": 1
        },
        "period_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "statistic": {
          "type": "string"
        },
        "value": {
          "type": "number"
        },
        "comparison": {
          "enum": [
            "<",
            "<=",
            ">",
            ">=",
            "==",
            "!="
          ]
        },
        "threshold": {
          "type": "number"
        },
        "degraded_threshold": {
          "type": "number"
        },
        "major_threshold": {
          "type": "number"
        },
        "label": {
          "type": "string"
        },
        "message": {
          "$ref": "#/$defs/localizedText"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "publicIncident": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "state",
        "title"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "state": {
          "$ref": "#/$defs/state"
        },
        "status": {
          "type": "string"
        },
        "date": {
          "$ref": "#/$defs/date"
        },
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "meta": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localizedText"
          }
        },
        "summary": {
          "$ref": "#/$defs/localizedText"
        },
        "footer": {
          "$ref": "#/$defs/localizedText"
        },
        "affected": {
          "type": "object",
          "additionalProperties": true
        },
        "updates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
