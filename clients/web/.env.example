# clients/web/.env.example
#
# Copy this file to: clients/web/.env.local
# - DO NOT commit clients/web/.env.local (it contains secrets)
#
# The temporary Web Chat MVP does not require login or secrets.
# Older dashboard/Auth.js screens are a separate lane and are not required for
# the temporary chat smoke path.

# Public Core API origin for the local Next rewrite. Loopback-only.
YONERAI_CORE_API_ORIGIN=http://127.0.0.1:8001

# Discord OAuth app credentials (Developer Portal)
# Only used for the older dashboard/Auth.js lane, not for the temporary Web Chat MVP.
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET

# Auth secrets (required in production; recommended in dev too)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_TO_RANDOM_32B
# Some Auth.js / NextAuth setups read AUTH_SECRET instead of NEXTAUTH_SECRET.
# Keep them the same to avoid confusion.
AUTH_SECRET=CHANGE_ME_TO_RANDOM_32B

# If you're behind a reverse proxy / tunnel, set this so NextAuth trusts the Host header.
AUTH_TRUST_HOST=true

# Optional: explicit canonical URL for NextAuth (use when deployed)
# NEXTAUTH_URL=https://your-domain.example
